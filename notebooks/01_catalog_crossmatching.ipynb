# ===============================================
# 📊 Multi-Mission Catalog Cross-Matching & Analysis
# ===============================================
# Description:
#   This notebook compares solar flare and GRB catalogs 
#   (Fermi/GBM, Fermi/LAT, Swift) by performing temporal 
#   and spatial cross-matching, followed by statistical analysis.
# ===============================================

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# -------------------------------------------------
# 1️⃣ SOLAR FLARE FLUX COMPARISON (GBM vs LAT)
# -------------------------------------------------
# Load dummy/sample data for demonstration
catalog_gbm = pd.read_csv("data/GBM_catalog.csv")
catalog_lat = pd.read_csv("data/LAT_catalog.csv")

# Normalize datetime columns
catalog_gbm['date'] = pd.to_datetime(catalog_gbm['date'])
catalog_lat['date'] = pd.to_datetime(catalog_lat['date'])

# Merge catalogs on common events
merged = pd.merge(catalog_gbm, catalog_lat, on='date', how='inner', suffixes=('_GBM', '_LAT'))
print(f"Total common events found: {len(merged)}")

# Compute parameter differences
comparison_df = merged[['date', 'flux_GBM', 'flux_LAT']].copy()
comparison_df['flux_diff'] = merged['flux_GBM'] - merged['flux_LAT']

print("\n--- Mean Difference Statistics ---")
print(comparison_df['flux_diff'].describe())

# Histogram Analysis
plt.figure(figsize=(8,5))
plt.hist(comparison_df['flux_diff'], bins=15, edgecolor='black', alpha=0.7, color='steelblue')
plt.title("Flux Difference Distribution (GBM - LAT)", fontsize=12)
plt.xlabel("Flux Difference", fontsize=10)
plt.ylabel("Frequency", fontsize=10)
plt.grid(True, linestyle='--', alpha=0.5)
plt.tight_layout()
plt.show()

# -------------------------------------------------
# 2️⃣ GRB CATALOG SPATIAL CROSS-MATCHING (SWIFT vs FERMI)
# -------------------------------------------------
# Load catalogs
swift = pd.read_csv("data/swift_all.txt", sep="\t", 
                    names=["grb_name", "time", "trig_number", "ra", "dec", "T90_bat"], comment="#")

fermi = pd.read_csv("data/fermi_all_burst.txt", sep="\t", 
                    names=["name", "ra", "dec", "trigger_tm", "t90", "t90_error", "t90_start"], comment="#")

# Classify GRBs based on T90 duration
fermi_long = fermi[fermi["t90"] >= 2.0]
fermi_short = fermi[fermi["t90"] < 2.0]

swift_long = swift[swift["T90_bat"] >= 2.0]
swift_short = swift[swift["T90_bat"] < 2.0]

print("\n---- SWIFT BURST OVERVIEW ----")
print(f"Short GRBs (T90 < 2s): {len(swift_short)}")
print(f"Long GRBs  (T90 >= 2s): {len(swift_long)}")

print("\n---- FERMI BURST OVERVIEW ----")
print(f"Short GRBs (T90 < 2s): {len(fermi_short)}")
print(f"Long GRBs  (T90 >= 2s): {len(fermi_long)}")

# Spatial Cross-Matching using RA/Dec Coordinates
tolerance_deg = 1.0  # 1 degree tolerance
matches = []

for _, sf in swift.iterrows():
    diff_ra = abs(fermi["ra"] - sf["ra"])
    diff_dec = abs(fermi["dec"] - sf["dec"])
    
    # Check if any event falls within the tolerance radius
    if any((diff_ra < tolerance_deg) & (diff_dec < tolerance_deg)):
        matches.append(sf)

common_df = pd.DataFrame(matches)
print(f"\nPotential common events (Spatial tolerance < {tolerance_deg}°): {len(common_df)}")