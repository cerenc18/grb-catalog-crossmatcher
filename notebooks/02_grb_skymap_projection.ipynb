# ===============================================
# 🌌 GRB Sky Map Projection (Mollweide)
# ===============================================
# Description:
#   This notebook visualizes the spatial distribution of Gamma-Ray 
#   Bursts (GRBs) from Swift and Fermi catalogs on a Mollweide 
#   projection. It highlights different populations (short vs long).
# ===============================================

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# -------------------------------------------------
# 1. LOAD DATASETS
# -------------------------------------------------
swift_cols = ['grb_name', 'time', 'trig_number', 'ra3', 'dec3', 'T90_bat']
fermi_cols = ['name1', 'ra_br', 'dec_br', 'trigger_tmbr', 't90', 't90_error', 't90_start']

# Assuming the data is in a 'data' folder
swift_df = pd.read_csv('data/swift_all.txt', delim_whitespace=True, names=swift_cols, comment='#')
fermi_df = pd.read_csv('data/fermi_all_burst.txt', delim_whitespace=True, names=fermi_cols, comment='#')

# -------------------------------------------------
# 2. BURST CLASSIFICATION (Short vs Long)
# -------------------------------------------------
# Swift Classification
short_sf = swift_df[swift_df['T90_bat'] < 2.0]
long_sf = swift_df[swift_df['T90_bat'] >= 2.0]

# Fermi Classification
short_fermi = fermi_df[fermi_df['t90'] < 2.0]
long_fermi = fermi_df[fermi_df['t90'] >= 2.0]

# -------------------------------------------------
# 3. COORDINATE TRANSFORMATION FOR SKY MAP
# -------------------------------------------------
def to_mollweide_coords(ra_deg, dec_deg):
    """
    Converts standard RA (0 to 360) to Mollweide projection compatible RA (-180 to 180).
    Dec remains in standard degrees, but converted to radians.
    """
    ra_rad = np.deg2rad(ra_deg)
    dec_rad = np.deg2rad(dec_deg)
    
    # Normalize RA
    ra_rad = np.remainder(ra_rad + 2*np.pi, 2*np.pi)  # 0 to 2pi
    ra_rad[ra_rad > np.pi] -= 2*np.pi  # Shift to -pi to pi
    
    return ra_rad, dec_rad

# Transform all datasets
ra_swift_all, dec_swift_all = to_mollweide_coords(swift_df['ra3'], swift_df['dec3'])
ra_fermi_all, dec_fermi_all = to_mollweide_coords(fermi_df['ra_br'], fermi_df['dec_br'])

ra_short_swift, dec_short_swift = to_mollweide_coords(short_sf['ra3'], short_sf['dec3'])
ra_long_swift, dec_long_swift = to_mollweide_coords(long_sf['ra3'], long_sf['dec3'])

ra_short_fermi, dec_short_fermi = to_mollweide_coords(short_fermi['ra_br'], short_fermi['dec_br'])
ra_long_fermi, dec_long_fermi = to_mollweide_coords(long_fermi['ra_br'], long_fermi['dec_br'])

# -------------------------------------------------
# 4. PLOTTING THE SKY MAP
# -------------------------------------------------
plt.figure(figsize=(14, 8))
ax = plt.subplot(111, projection="mollweide")

# Background and Grid
ax.set_facecolor('black')
ax.grid(True, color='white', linestyle='dotted', linewidth=0.5, alpha=0.7)

# -------------------------------------------------
# 5. DATA SCATTER PLOTS
# -------------------------------------------------
# Background Population
ax.scatter(ra_swift_all, dec_swift_all, s=10, color='white', alpha=0.3, label='Swift All')
ax.scatter(ra_fermi_all, dec_fermi_all, s=10, color='deepskyblue', alpha=0.3, label='Fermi All')

# Highlighted Populations
ax.scatter(ra_short_swift, dec_short_swift, s=25, color='limegreen', marker='^', alpha=0.8, label='Swift Short ($T_{90}$ < 2s)')
ax.scatter(ra_long_swift, dec_long_swift, s=25, color='red', marker='s', alpha=0.8, label='Swift Long ($T_{90}$ $\geq$ 2s)')

ax.scatter(ra_short_fermi, dec_short_fermi, s=25, color='yellow', marker='v', alpha=0.8, label='Fermi Short ($T_{90}$ < 2s)')
ax.scatter(ra_long_fermi, dec_long_fermi, s=25, color='cyan', marker='o', alpha=0.8, label='Fermi Long ($T_{90}$ $\geq$ 2s)')

# -------------------------------------------------
# 6. VISUAL AESTHETICS
# -------------------------------------------------
ax.set_title("Spatial Distribution of Gamma-Ray Bursts (Swift BAT & Fermi GBM)", fontsize=16, color='black', pad=20)
ax.legend(loc='lower center', bbox_to_anchor=(0.5, -0.15), ncol=3, frameon=False, fontsize=10, labelcolor='black')

# Adjust tick labels
xticks = np.array([-150, -120, -90, -60, -30, 0, 30, 60, 90, 120, 150])
ax.set_xticklabels([f"{int(t)}°" for t in xticks])

plt.subplots_adjust(top=0.95, bottom=0.15)
plt.tight_layout()
plt.show()